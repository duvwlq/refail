# Local and CI smoke-test values only. Never use these credentials in production.
APP_DOMAIN=localhost
PUBLIC_ORIGIN=https://localhost:18443
HTTP_PORT=18000
HTTPS_PORT=18443
CADDYFILE_PATH=./ops/caddy/Caddyfile.local

MYSQL_DATABASE=fail
MYSQL_USERNAME=fail
MYSQL_PASSWORD=smoke-database-password
MYSQL_ROOT_PASSWORD=smoke-root-password

JWT_SECRET=smoke-jwt-secret-that-is-longer-than-forty-eight-characters-1234
JWT_ACCESS_TOKEN_VALIDITY_SECONDS=900
JWT_REFRESH_TOKEN_VALIDITY_SECONDS=2592000
JWT_REFRESH_REUSE_GRACE_SECONDS=5

SEARCH_FULLTEXT_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_ENTRIES=10000
RATE_LIMIT_LOGIN_LIMIT=100
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_SIGNUP_LIMIT=100
RATE_LIMIT_SIGNUP_WINDOW_SECONDS=3600
RATE_LIMIT_REFRESH_LIMIT=100
RATE_LIMIT_REFRESH_WINDOW_SECONDS=60
RATE_LIMIT_REPORT_LIMIT=100
RATE_LIMIT_REPORT_WINDOW_SECONDS=3600

MANAGEMENT_PORT=9090
HIBERNATE_SQL_LOG_LEVEL=warn

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=smoke-grafana-password
