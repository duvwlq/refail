# Copy to .env.production on the server and replace every change-me value.
APP_DOMAIN=refail.example.com
PUBLIC_ORIGIN=https://refail.example.com
HTTP_PORT=80
HTTPS_PORT=443
CADDYFILE_PATH=./ops/caddy/Caddyfile

MYSQL_DATABASE=fail
MYSQL_USERNAME=fail
MYSQL_PASSWORD=change-me-database-password
MYSQL_ROOT_PASSWORD=change-me-root-password

# Use at least 48 random characters.
JWT_SECRET=change-me-jwt-secret-with-at-least-48-characters
JWT_ACCESS_TOKEN_VALIDITY_SECONDS=900
JWT_REFRESH_TOKEN_VALIDITY_SECONDS=2592000
JWT_REFRESH_REUSE_GRACE_SECONDS=5

SEARCH_FULLTEXT_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_ENTRIES=10000
RATE_LIMIT_LOGIN_LIMIT=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_SIGNUP_LIMIT=3
RATE_LIMIT_SIGNUP_WINDOW_SECONDS=3600
RATE_LIMIT_REFRESH_LIMIT=10
RATE_LIMIT_REFRESH_WINDOW_SECONDS=60
RATE_LIMIT_REPORT_LIMIT=5
RATE_LIMIT_REPORT_WINDOW_SECONDS=3600

MANAGEMENT_PORT=9090
HIBERNATE_SQL_LOG_LEVEL=warn

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
