        {
          "expr": "sum(jvm_memory_max_bytes{application=\"fail\",area=\"heap\"})",
          "legendFormat": "최대"
        }
      ],
      "title": "JVM Heap",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "id": 5,
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"fail\"}",
